{
  "name": "ngx-smart-editor",
  "version": "0.1.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "build:lib": "npm run sync:readme && ng build ngx-smart-editor",
    "build:lib:watch": "npm run sync:readme && ng build ngx-smart-editor --watch --configuration development",
    "publish:lib": "npm run build:lib && npm publish ./dist/ngx-smart-editor",
    "sync:readme": "cp README.md projects/ngx-smart-editor/README.md",
    "version:check:lib": "node -e \"const pkg=require('./projects/ngx-smart-editor/package.json'); console.log('Library version:', pkg.version); console.log('Update projects/ngx-smart-editor/package.json before publishing if needed.');\""
  },
  "private": true,
  "packageManager": "npm@10.9.4",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.2",
    "@angular/cli": "^21.2.2",
    "@angular/compiler-cli": "^21.2.0",
    "jsdom": "^28.0.0",
    "ng-packagr": "^21.2.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
